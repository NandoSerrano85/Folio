# Folio configuration. Copy to `.env` and fill in.
# Every key here maps 1:1 to folio_core.config.Settings.

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# SQLAlchemy URL used by the app (psycopg v3 driver). Host "db" is the compose
# service name. Keep user/password/db in sync with the POSTGRES_* values below.
DATABASE_URL=postgresql+psycopg://folio:folio@db:5432/folio

# Consumed by the postgres container to initialize the cluster.
POSTGRES_USER=folio
POSTGRES_PASSWORD=folio
POSTGRES_DB=folio

# ----------------------------------------------------------------------------
# Filesystem layout (paths INSIDE the containers; mapped to volumes in compose)
# ----------------------------------------------------------------------------
# Root of the original-image library (worker writes, portal reads).
MEDIA_ROOT=/data/media
# On-demand thumbnail cache (portal writes).
THUMBNAIL_ROOT=/data/thumbnails
# Per-account ENCRYPTED OAuth refresh tokens.
TOKEN_DIR=/data/tokens

# ----------------------------------------------------------------------------
# Crypto / secrets
# ----------------------------------------------------------------------------
# Fernet key for encrypting OAuth tokens at rest. REQUIRED. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Secret used to sign the portal session cookie. REQUIRED — the portal refuses
# to start without it (a guessable key lets anyone forge a logged-in cookie).
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
PORTAL_SECRET_KEY=

# Add the Secure flag to the session cookie. Leave false for plain-HTTP LAN
# access (http://NAS-IP:8080); set true only when the portal is served over
# HTTPS (reverse proxy / TLS VPN), else the cookie won't be sent and you can't
# stay logged in.
SESSION_HTTPS_ONLY=false

# ----------------------------------------------------------------------------
# Google OAuth (installed-app flow, READ-ONLY scopes only)
# ----------------------------------------------------------------------------
# Path (inside the container) to the OAuth client secrets JSON.
GOOGLE_CLIENT_SECRETS_FILE=/data/secrets/google_client_secret.json
# Space-separated scopes. READ-ONLY by policy — do not widen these.
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/drive.readonly

# ----------------------------------------------------------------------------
# Portal admin bootstrap (seeded on first boot only)
# ----------------------------------------------------------------------------
ADMIN_USERNAME=admin
# Set a strong password before first boot; required to seed the admin user.
ADMIN_PASSWORD=

# ----------------------------------------------------------------------------
# Portal access token (alternative to username+password at /api/auth/login)
# ----------------------------------------------------------------------------
# argon2id HASH of the access token. The plaintext token is NEVER stored here.
# Mint a token + this line (then paste the printed TOKEN into the portal):
#   python services/portal/scripts/make_token.py
# Or inline:
#   python -c "from argon2 import PasswordHasher; import secrets; t='folio_sk_live_'+secrets.token_urlsafe(24); print('TOKEN:',t); print('ACCESS_TOKEN_HASH=',PasswordHasher().hash(t))"
# Keep the printed TOKEN secret (paste it into the portal); only the hash goes here.
ACCESS_TOKEN_HASH=

# ----------------------------------------------------------------------------
# Worker scheduler intervals (minutes)
# ----------------------------------------------------------------------------
SYNC_DRIVE_INTERVAL_MINUTES=30
DISCOVER_SENDERS_INTERVAL_MINUTES=720
RECONCILE_INTERVAL_MINUTES=1440

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
# DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
# exiftool executable name/path (installed in the worker image).
EXIFTOOL_BINARY=exiftool
# Default thumbnail edge size in pixels.
THUMBNAIL_DEFAULT_SIZE=320
# Scheduler / display timezone.
TIMEZONE=UTC
