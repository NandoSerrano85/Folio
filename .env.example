# Folio configuration. Copy to `.env` and fill in.
# Most keys map 1:1 to folio_core.config.Settings; PORTAL_PORT below is read by
# docker compose (not the app).

# ----------------------------------------------------------------------------
# Deployment (docker compose)
# ----------------------------------------------------------------------------
# Host port the portal is published on. QNAP's QTS admin UI listens on 8080, so
# the default is 8899 to avoid "address already in use". Browse to
# http://NAS-IP:8899 (the container always serves on 8080 internally).
PORTAL_PORT=8899

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# SQLAlchemy URL used by the app (psycopg v3 driver). Host "db" is the compose
# service name. Keep user/password/db in sync with the POSTGRES_* values below.
DATABASE_URL=postgresql+psycopg://folio:folio@db:5432/folio

# Consumed by the postgres container to initialize the cluster. Keep
# POSTGRES_PASSWORD free of '$': Docker Compose interpolates ${POSTGRES_PASSWORD}
# in the db service, where a '$' is read as a variable reference.
POSTGRES_USER=folio
POSTGRES_PASSWORD=folio
POSTGRES_DB=folio

# ----------------------------------------------------------------------------
# Filesystem layout (paths INSIDE the containers; mapped to volumes in compose)
# ----------------------------------------------------------------------------
# Root of the original-image library (worker writes, portal reads).
MEDIA_ROOT=/data/media
# On-demand thumbnail cache (portal writes).
THUMBNAIL_ROOT=/data/thumbnails
# Per-account ENCRYPTED OAuth refresh tokens.
TOKEN_DIR=/data/tokens

# ----------------------------------------------------------------------------
# Crypto / secrets
# ----------------------------------------------------------------------------
# Fernet key for encrypting OAuth tokens at rest. REQUIRED. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Secret used to sign the portal session cookie. REQUIRED — the portal refuses
# to start without it (a guessable key lets anyone forge a logged-in cookie).
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
PORTAL_SECRET_KEY=

# Add the Secure flag to the session cookie. Leave false for plain-HTTP LAN
# access (http://NAS-IP:8899); set true only when the portal is served over
# HTTPS (reverse proxy / TLS VPN), else the cookie won't be sent and you can't
# stay logged in.
SESSION_HTTPS_ONLY=false

# ----------------------------------------------------------------------------
# Google OAuth (installed-app flow, READ-ONLY scopes only)
# ----------------------------------------------------------------------------
# Path (inside the container) to the OAuth client secrets JSON.
GOOGLE_CLIENT_SECRETS_FILE=/data/secrets/google_client_secret.json
# Space-separated scopes. READ-ONLY by policy — do not widen these.
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/drive.readonly

# ----------------------------------------------------------------------------
# Portal admin bootstrap (seeded on first boot only)
# ----------------------------------------------------------------------------
ADMIN_USERNAME=admin
# Set a strong password before first boot; required to seed the admin user.
ADMIN_PASSWORD=

# ----------------------------------------------------------------------------
# Portal access token (alternative to username+password at /api/auth/login)
# ----------------------------------------------------------------------------
# argon2id HASH of the access token. The plaintext token is NEVER stored here.
# (The app reads this .env file directly, so the '$' in the argon2 hash is safe.)
# Mint a token + this line (then paste the printed TOKEN into the portal):
#   python services/portal/scripts/make_token.py
# Or inline:
#   python -c "from argon2 import PasswordHasher; import secrets; t='folio_sk_live_'+secrets.token_urlsafe(24); print('TOKEN:',t); print('ACCESS_TOKEN_HASH=',PasswordHasher().hash(t))"
# Keep the printed TOKEN secret (paste it into the portal); only the hash goes here.
ACCESS_TOKEN_HASH=

# ----------------------------------------------------------------------------
# Worker scheduler intervals (minutes)
# ----------------------------------------------------------------------------
SYNC_DRIVE_INTERVAL_MINUTES=30
DISCOVER_SENDERS_INTERVAL_MINUTES=720
RECONCILE_INTERVAL_MINUTES=1440
# How often the vendor-browser Gmail ingestion runs. It only actually fires
# inside the off-hours window below AND when BROWSER_ENABLED=true.
GMAIL_SYNC_INTERVAL_MINUTES=360

# ----------------------------------------------------------------------------
# Vendor browser (headless Chromium via Playwright)
# ----------------------------------------------------------------------------
# Chromium is RAM-hungry. On the 8 GB QNAP these jobs run ONE AT A TIME and
# only during the off-hours window. Set BROWSER_ENABLED=false to disable
# vendor-browser ingestion entirely.
BROWSER_ENABLED=true
# Run Chromium headless. Keep true in production.
BROWSER_HEADLESS=true
# Per-navigation timeout (seconds) for Playwright page operations.
BROWSER_NAV_TIMEOUT_SECONDS=45
# Scratch directory (inside the container) for browser-downloaded originals.
BROWSER_DOWNLOAD_DIR=/data/tmp/downloads
# Off-hours window in LOCAL hours (TIMEZONE below). Overnight windows are
# supported: if START > END (e.g. 22..6) the window wraps past midnight. The
# job runs only inside the window.
BROWSER_OFFHOURS_START=1
BROWSER_OFFHOURS_END=6
# Max concurrent vendor-browser jobs. MUST stay 1 on 8 GB RAM.
VENDOR_BROWSER_MAX_JOBS=1

# ----------------------------------------------------------------------------
# Database backups (pg_dump custom format via `worker backup-db`)
# ----------------------------------------------------------------------------
# Destination (inside the container; mapped to the `backups` volume) for
# timestamped pg_dump archives.
BACKUP_DIR=/data/backups
# Dumps older than this many days are pruned after each successful backup.
BACKUP_RETENTION_DAYS=14

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
# DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
# exiftool executable name/path (installed in the worker image).
EXIFTOOL_BINARY=exiftool
# Default thumbnail edge size in pixels.
THUMBNAIL_DEFAULT_SIZE=320
# Scheduler / display timezone.
TIMEZONE=UTC
