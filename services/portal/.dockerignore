# Keep the offline design-preview out of the production image. demo.html and
# demo-data.js are only used by the local parity preview (window.FOLIO_DEMO);
# the production app never imports them, so they must not be web-reachable from
# the public /static mount in prod.
portal/static/demo.html
portal/static/js/demo-data.js

# Build/cache cruft that should never ship in the image.
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
